# Default: normalize text files to LF on commit
* text=auto eol=lf

# Kotlin / Gradle
*.kt          text eol=lf diff=kotlin
*.kts         text eol=lf diff=kotlin
*.gradle      text eol=lf
gradlew       text eol=lf
gradlew.bat   text eol=crlf

# Protobuf
*.proto       text eol=lf

# Config / infra
*.conf        text eol=lf
*.yaml        text eol=lf
*.yml         text eol=lf
*.json        text eol=lf
*.xml         text eol=lf
*.toml        text eol=lf
*.properties  text eol=lf
Dockerfile    text eol=lf
dockerfile    text eol=lf

# Scripts
*.sh          text eol=lf
*.lua         text eol=lf
*.js          text eol=lf
*.py          text eol=lf

# Docs
*.md          text eol=lf
*.adoc        text eol=lf

# Windows scripts
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# Binaries — no line-ending conversion, no diff
*.jar         binary
*.class       binary
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.zip         binary
*.tar.gz      binary
*.pyc         binary

# Linguist overrides
gradlew.bat   linguist-detectable=false
*.lua         linguist-detectable=false
