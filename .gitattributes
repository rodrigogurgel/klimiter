# Default: normalise line endings to LF on commit
* text=auto eol=lf

# Kotlin / Gradle
*.kt        text eol=lf diff=kotlin
*.kts       text eol=lf diff=kotlin

# Protobuf
*.proto     text eol=lf

# Config / infra
*.yaml      text eol=lf
*.yml       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.toml      text eol=lf
*.properties text eol=lf

# Scripts
*.sh        text eol=lf
*.lua       text eol=lf
*.js        text eol=lf

# Gradle wrapper — keep platform-specific endings
gradlew     text eol=lf
gradlew.bat text eol=crlf

# Docs
*.md        text eol=lf
*.adoc      text eol=lf

# Binaries — no line-ending conversion, no diff
*.jar       binary
*.class     binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.tar.gz    binary

# Linguist overrides (GitHub language stats)
gradlew.bat linguist-detectable=false
*.lua       linguist-detectable=false
